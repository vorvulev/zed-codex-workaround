// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "Codex-CLI": {
      "type": "custom",
      "command": "/Users/user/.local/codex-acp-0.10.0/node_modules/.bin/codex-acp-darwin-arm64",
      "args": []
    }
  },
  "agent": {
    "dock": "right",
    "single_file_review": true
  },
  "which_key": {
    "enabled": false
  },
  "autosave": "off",
  // "outline_panel": { "dock": "right" },
  "show_edit_predictions": false,
  "git": {
    "disable_git": false,
    "enable_status": true
  },
  "use_system_window_tabs": true,
  "bottom_dock_layout": "left_aligned",
  "preview_tabs": {
    "enable_preview_from_file_finder": true
  },
  "tabs": {
    "file_icons": true
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": true
  },
  "title_bar": {
    "show_menus": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_branch_icon": false,
    "show_sign_in": false,
    "show_user_menu": true,
    "show_user_picture": false,
    "show_branch_name": true
  },
  "debugger": {
    "button": false
  },
  "diagnostics": {
    "button": true
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_encoding_button": "enabled",
    "active_language_button": true
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
    "bold_folder_labels": false,
    "auto_reveal_entries": true,
    "folder_icons": true,
    "hide_gitignore": true,
    "default_width": 240.0,
    "button": true
  },
  "enable_language_server": true,
  "inlay_hints": {
    "enabled": false
  },
  "show_whitespaces": "boundary",
  "toolbar": {
    "quick_actions": true,
    "selections_menu": true,
    "code_actions": false
  },
  "minimap": {
    "show": "never"
  },
  "sticky_scroll": {
    "enabled": true
  },
  "diff_view_style": "unified",
  "session": {
    "trust_all_worktrees": true
  },
  "restore_on_startup": "launchpad",
  "scrollbar": {
    "git_diff": true
  },
  "hard_tabs": true,
  "remove_trailing_whitespace_on_save": true,
  "format_on_save": "off",
  "auto_indent_on_paste": true,
  "auto_indent": "syntax_aware",
  "terminal": {
      "copy_on_select": true,
      "font_family": "Hack Nerd Font"
    },
  "ui_font_weight": 400.0,
  "ui_font_family": "Menlo",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "buffer_font_family": "Menlo",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Frappé"
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark"
  },
  "theme_overrides": {
      "One Dark": {
          "created": "#62c755",
          "created.background": "#62c75540",
          "created.border": "#62c755",
          "deleted": "#ec6a5e",
          "deleted.background": "#ec6a5e40",
          "deleted.border": "#ec6a5e",
          "modified": "#f5bf4f",
          "modified.background": "#f5bf4f40",
          "modified.border": "#f5bf4f"
      }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "liquid": "html"
        }
      }
    }
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/.sl",
    "**/.repo",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "assets/"
  ],
  "languages": {
    "Liquid": {
      "prettier": {
        "allowed": true,
        "plugins": [
          "@shopify/prettier-plugin-liquid",
          "prettier-plugin-tailwindcss"
                ]
              },
              "language_servers": []
    }
  }
}
